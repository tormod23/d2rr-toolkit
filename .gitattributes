# ============================================================
# D2RR Toolkit .gitattributes
# Cross-platform line-ending normalization and binary handling
# ============================================================

# --- Default: normalize all text files to LF ---
* text=auto eol=lf

# --- Explicit text files (defensive, against false auto-detection) ---
*.py     text eol=lf
*.md     text eol=lf
*.json   text eol=lf
*.toml   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf

# --- LICENSE has no extension; force text+LF ---
LICENSE  text eol=lf

# --- Windows-only scripts: keep CRLF ---
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# --- Binary file types (never converted, never diffed as text) ---
*.d2s    binary
*.d2i    binary

# --- D2 binary fixtures with custom suffix tags (e.g. CubeContents.d2s.GAME) ---
# Match any extension AFTER .d2s or .d2i
*.d2s.*  binary
*.d2i.*  binary